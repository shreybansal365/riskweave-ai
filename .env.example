# RiskWeave Milestone 1 local foundation
APP_NAME=RiskWeave API
APP_VERSION=0.1.0
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# PostgreSQL is the only runtime database.
POSTGRES_DB=riskweave
POSTGRES_USER=riskweave
POSTGRES_PASSWORD=riskweave-local-only
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://riskweave:riskweave-local-only@db:5432/riskweave

# Browser-visible frontend configuration.
FRONTEND_PORT=4173
VITE_API_BASE_URL=http://localhost:8000

# Reserved for approved later authentication and simulation milestones.
# These values are not consumed by Milestone 1.
JWT_SECRET=replace-before-authentication-is-implemented
ACCESS_TOKEN_TTL_MINUTES=15
DEMO_ADMIN_EMAIL=admin@example.invalid
DEMO_ADMIN_PASSWORD=replace-before-authentication-is-implemented
DEMO_ANALYST_EMAIL=analyst@example.invalid
DEMO_ANALYST_PASSWORD=replace-before-authentication-is-implemented
DEMO_SEED=26026
MODEL_RANDOM_SEED=26026
SIMULATION_EPOCH=2026-07-14T09:00:00Z
