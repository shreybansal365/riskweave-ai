# RiskWeave local and release configuration template
APP_NAME=RiskWeave API
APP_VERSION=0.5.0
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# PostgreSQL is the only runtime database.
POSTGRES_DB=riskweave
POSTGRES_USER=riskweave
POSTGRES_PASSWORD=riskweave-local-only
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://riskweave:riskweave-local-only@database:5432/riskweave

# Browser-visible frontend configuration.
FRONTEND_PORT=4173
VITE_API_BASE_URL=http://localhost:8000

# Authentication secrets are intentionally blank. Set strong local-only values before seeding users.
JWT_SECRET=
ACCESS_TOKEN_TTL_MINUTES=15
AUTH_FAILURE_LIMIT=5
AUTH_FAILURE_WINDOW_SECONDS=60

# Locked deterministic simulation contract. Changing these values is rejected.
DEMO_SEED=26026
MODEL_RANDOM_SEED=26026
SIMULATION_EPOCH=2026-07-14T09:00:00Z
DEMO_ADMIN_EMAIL=admin@riskweave.demo
DEMO_ADMIN_PASSWORD=
DEMO_ANALYST_EMAIL=analyst@riskweave.demo
DEMO_ANALYST_PASSWORD=

# Guard for the one-shot hosted bootstrap command. Set exactly to baseline-v1 only while running
# `python -m app.cli.bootstrap_release`; the command refuses partial or unexpected datasets.
RELEASE_BOOTSTRAP_CONFIRM=

# Browser-test endpoints and synthetic test identities. Passwords may reuse the demo-user
# values locally, but remain explicit and uncommitted.
E2E_BASE_URL=http://localhost:4173
E2E_API_URL=http://localhost:8000
E2E_RUN_ID=
E2E_ADMIN_EMAIL=admin@riskweave.demo
E2E_ADMIN_PASSWORD=
E2E_ANALYST_EMAIL=analyst@riskweave.demo
E2E_ANALYST_PASSWORD=
